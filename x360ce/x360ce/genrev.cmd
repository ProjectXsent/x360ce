@echo off
:: Generate svnrev.h from git history.
:: Drop-in replacement for the legacy SVN-based svnrev.exe stamper.
setlocal EnableExtensions EnableDelayedExpansion

set "OUT=%~dp0svnrev.h"

:: Defaults if git is missing or this is not a working copy.
set "REV=0"
set "REVDATE=0000-00-00"
set "MODIFIED=0"

where git >nul 2>nul
if not errorlevel 1 (
    for /f "delims=" %%i in ('git rev-list --count HEAD 2^>nul') do set "REV=%%i"
    for /f "delims=" %%i in ('git log -1 --date^=short --format^=%%cd 2^>nul') do set "REVDATE=%%i"
    git diff --quiet HEAD -- 2>nul
    if errorlevel 1 set "MODIFIED=1"
)

:: REVSTAMP = REVDATE with dashes stripped, "L" suffix for long literal.
set "REVSTAMP=!REVDATE:-=!"

> "%OUT%" echo /* Generated by genrev.cmd from git. Do not edit. */
>> "%OUT%" echo #ifndef SVN_REV_H
>> "%OUT%" echo #define SVN_REV_H
>> "%OUT%" echo.
>> "%OUT%" echo #define SVN_REV         !REV!
>> "%OUT%" echo #define SVN_REVSTR      "!REV!"
>> "%OUT%" echo #define SVN_REVDATE     "!REVDATE!"
>> "%OUT%" echo #define SVN_REVSTAMP    !REVSTAMP!L
>> "%OUT%" echo #define SVN_REVMODIFIED !MODIFIED!
>> "%OUT%" echo.
>> "%OUT%" echo #endif /* SVN_REV_H */

endlocal
exit /b 0
